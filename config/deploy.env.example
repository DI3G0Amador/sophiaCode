# Chaves de API para os provedores de IA (NÃO commitar chaves reais!)
# Copie este arquivo como '.env' na raiz do seu projeto ou use variáveis de ambiente globais.

# Provedor Google Gemini (recomendado)
GEMINI_API_KEY=sua_chave_do_gemini_aqui

# Provedor OpenAI (alternativo)
OPENAI_API_KEY=sua_chave_da_openai_aqui

# Endpoint customizado para Ollama (caso queira rodar localmente e apontar para outra máquina)
# OLLAMA_BASE_URL=http://localhost:11434/v1
