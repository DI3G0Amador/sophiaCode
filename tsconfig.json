{
  "compilerOptions": {
    /* Alvo e ambiente */
    "target": "ES2022", /* Define qual versão do JS será gerada. ES2022 é moderno e suportado pelo Node recente. */
    "module": "NodeNext", /* Define como os módulos serão importados. NodeNext é o padrão para suportar ESM moderno no Node. */
    "moduleResolution": "NodeNext", /* Como o TypeScript procura os arquivos importados. NodeNext garante consistência com o Node. */
    /* Strict Checks (Garantia de qualidade) */
    "strict": true, /* Ativa todas as verificações rígidas de tipo para evitar erros comuns em runtime. */
    "noImplicitAny": true, /* Impede que variáveis fiquem com tipo implícito 'any'. */
    "strictNullChecks": true, /* Garante que você trate possíveis valores 'null' ou 'undefined' antes de acessá-los. */
    /* Outras preferências */
    "esModuleInterop": true, /* Facilita a importação de módulos CommonJS antigos usando sintaxe moderna. */
    "skipLibCheck": true, /* Ignora a verificação de tipo dentro dos arquivos node_modules para acelerar a compilação. */
    "forceConsistentCasingInFileNames": true /* Garante que caminhos com maiúsculas/minúsculas diferentes não causem erros em SOs diferentes (Windows vs Linux). */
  },
  "include": [
    "src/**/*",
    "tests/**/*"
  ] /* Diz ao compilador para olhar os arquivos dentro de src e tests. */
}